OPENAI_API_KEY=
OPENAI_PRIMARY_MODEL=gpt-4o
OPENAI_REPLAY_MODEL=gpt-4o-mini
OPENAI_JUDGE_MODEL=gpt-4o
AGENTREWIND_USE_MOCK_LLM=false
AGENTREWIND_FRONTEND_ORIGIN=http://localhost:5173
AGENTREWIND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AGENTREWIND_TRUSTED_HOSTS=localhost,127.0.0.1,testserver
AGENTREWIND_REQUIRE_HTTPS=false
AGENTREWIND_AUTH_TOKENS=
AGENTREWIND_STATE_DB_PATH=D:\AgentRewind\backend\state\agentrewind.sqlite3
AGENTREWIND_IMPORTED_TRACE_DIR=D:\AgentRewind\backend\imported_traces
AGENTREWIND_LLM_TIMEOUT_SECONDS=45
AGENTREWIND_LLM_MAX_RETRIES=2
AGENTREWIND_LLM_MAX_CONCURRENCY=8
AGENTREWIND_IMPORT_MAX_PAYLOAD_BYTES=2000000
AGENTREWIND_IMPORT_MAX_STEPS=250
AGENTREWIND_IMPORT_MAX_TEXT_CHARS=6000
AGENTREWIND_IMPORT_MAX_LIST_ENTRIES=50
AGENTREWIND_LLM_MAX_TRACE_CHARS=24000
AGENTREWIND_RATE_LIMIT_REQUESTS_PER_MINUTE=240
AGENTREWIND_RATE_LIMIT_HEAVY_REQUESTS_PER_MINUTE=40
AGENTREWIND_JOB_WORKER_CONCURRENCY=4
AGENTREWIND_JOB_RETENTION_SECONDS=86400
